# ══════════════════════════════════════════════════════════════════════════════
# Data Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to Git.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Data Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=False

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://dip_user:dip_pass@localhost:5432/dip_db

# Set to True during development to see every SQL query in the logs
DB_ECHO_SQL=False

# ── Scraping behaviour ────────────────────────────────────────────────────────
# Random delay range between HTTP requests (seconds) — be polite
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=3.5

# HTTP request timeout (seconds)
SCRAPE_TIMEOUT=30

# How many times to retry a failed request before giving up
SCRAPE_MAX_RETRIES=3

# Set to False during development to watch the browser window
PLAYWRIGHT_HEADLESS=True

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=True

# How often each source is scraped automatically (hours)
DEFAULT_SCRAPE_INTERVAL_HOURS=6

# ── Alerts (optional) ─────────────────────────────────────────────────────────
ALERT_EMAIL_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ══════════════════════════════════════════════════════════════════════════════
# Data Intelligence Platform — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
wheels/
pip-wheel-metadata/

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Database & local storage ──────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
scheduler_jobs.db
postgres_data/
pgadmin_data/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
log/

# ── Playwright ────────────────────────────────────────────────────────────────
playwright/.local-browsers/
playwright-report/
test-results/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── IDE & editors ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*~

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── Node / React frontend ─────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.next/
out/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/

*_files/
*.html
!frontend/**/*.html
saved_resource*